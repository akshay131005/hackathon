# MongoDB Atlas connection string (required). Get it from: Atlas → Cluster → Connect → Connect your application
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/privacypass?retryWrites=true&w=majority
PORT=4000
JWT_SECRET=super-secret-jwt
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CONTRACT_ADDRESS=0xYourPrivacyPassAddress
ISSUER_JWT_SECRET=super-secret-issuer
ALLOWED_ORIGIN=http://localhost:5173
# Optional: base URL for verify links in credentials (e.g. https://api.yourapp.com). Defaults to http://localhost:4000
# API_BASE_URL=http://localhost:4000
